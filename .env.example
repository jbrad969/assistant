# OpenAI (used for memory extraction and quote-detail extraction)
OPENAI_API_KEY=sk-...

# Anthropic (Claude — used for all conversational replies)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (memory table)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google OAuth (Gmail + Calendar)
# Create at https://console.cloud.google.com/ -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/google/callback
# Generated by visiting /api/auth/gmail and copying the refresh_token from the callback response
GOOGLE_REFRESH_TOKEN=1//...

# Primary account address — used to tag emails/files so Jess can say
# "Found this in brad@solarfixaz.com inbox" / "...in solar@solarfixaz.com inbox".
GOOGLE_EMAIL=brad@solarfixaz.com

# Second Google account (Gmail + Drive). Generate the refresh token the same
# way as GOOGLE_REFRESH_TOKEN but while logged in as the second account.
GOOGLE_REFRESH_TOKEN_2=1//...
GOOGLE_EMAIL_2=solar@solarfixaz.com

# Google Maps (Distance Matrix API for traffic-based departure alerts)
# Enable at https://console.cloud.google.com/ -> APIs & Services -> Library -> Distance Matrix API
GOOGLE_MAPS_API_KEY=AIza...

# Base URL for internal self-fetches from the chat route
# Local: http://localhost:3000   Production: https://your-domain.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
