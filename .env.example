# OpenAI
OPENAI_API_KEY=sk-...

# Supabase (memory table)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google OAuth (Gmail + Calendar)
# Create at https://console.cloud.google.com/ -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Must match the redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/google/callback
# Generated by visiting /api/auth/gmail and copying the refresh_token from the callback response
GOOGLE_REFRESH_TOKEN=1//...

# Google Maps (Distance Matrix API for traffic-based departure alerts)
# Enable at https://console.cloud.google.com/ -> APIs & Services -> Library -> Distance Matrix API
GOOGLE_MAPS_API_KEY=AIza...

# Base URL for internal self-fetches from the chat route
# Local: http://localhost:3000   Production: https://your-domain.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
